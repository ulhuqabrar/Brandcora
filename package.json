{
  "name": "saas-foundation",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @saas/web dev & pnpm --filter @saas/api dev",
    "dev:web": "pnpm --filter @saas/web dev",
    "dev:api": "pnpm --filter @saas/api dev",
    "build": "pnpm --filter @saas/shared build && pnpm --filter @saas/ui build && pnpm --filter @saas/database build && pnpm --filter @saas/web build && pnpm --filter @saas/api build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @saas/database generate",
    "db:push": "pnpm --filter @saas/database push",
    "db:migrate": "pnpm --filter @saas/database migrate",
    "db:seed": "pnpm --filter @saas/database seed",
    "db:studio": "pnpm --filter @saas/database studio",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.4"
}
