# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── URLs ──────────────────────────────────────────────────────────────────────
# Development
WEB_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001

# Production (Render) — set these on Render dashboard
# WEB_APP_URL=https://brandcora.vercel.app
# API_BASE_URL=https://brandcora-api.onrender.com

# ─── Better Auth ───────────────────────────────────────────────────────────────
# Development
BETTER_AUTH_SECRET=your-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3001/api/auth

# Production (Render) — MUST point to the FRONTEND domain for OAuth callbacks
# Better Auth uses this to construct the Google OAuth redirect_uri
# If this is wrong, Google will reject the callback with "redirect_uri_mismatch"
# BETTER_AUTH_URL=https://brandcora.vercel.app/api/auth

# ─── Database (Neon) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origin: https://brandcora.vercel.app
# Authorized redirect URI: https://brandcora.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth (Optional) ───────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Apple OAuth (Optional) ───────────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe Price IDs (from Stripe dashboard) ──────────────────────────────────
STRIPE_PRICE_ID_STARTER_MONTHLY=
STRIPE_PRICE_ID_STARTER_YEARLY=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_BUSINESS_MONTHLY=
STRIPE_PRICE_ID_BUSINESS_YEARLY=
STRIPE_PRICE_ID_BRAND_GUARD_LITE_MONTHLY=

# ─── Frontend (Vercel) ────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL is no longer needed — the Next.js proxy handles routing.
# All /api/* requests from the browser go through the same origin via rewrites.
# Do NOT set NEXT_PUBLIC_API_URL on Vercel.
